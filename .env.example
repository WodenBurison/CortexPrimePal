# Copy this file to .env and fill in your values

# Bot token from https://discord.com/developers/applications
DISCORD_TOKEN=your_bot_token_here

# Application/Client ID from the same page
CLIENT_ID=your_application_client_id_here

# Optional: your server (guild) ID for instant command deployment during development.
# Leave blank to deploy commands globally (takes up to 1 hour to update).
GUILD_ID=your_server_id_here
